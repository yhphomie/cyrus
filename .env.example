# Cyrus environment for local Docker testing
# Copy to .env and fill in values

# Linear OAuth (from your Linear OAuth Application settings)
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
LINEAR_WEBHOOK_SECRET=

# For local testing, this would be your tunnel URL or localhost
# For Cloudflare, this is set automatically to the worker URL
CYRUS_BASE_URL=https://cyrusworker.YOUR_ACCOUNT.workers.dev

# Claude Code
ANTHROPIC_API_KEY=

# GitHub (for PR creation)
GH_TOKEN=
GIT_USER_NAME=Cyrus
GIT_USER_EMAIL=cyrus@example.com

# Cyrus server settings
CYRUS_HOST_EXTERNAL=true
CYRUS_SERVER_PORT=3456
LINEAR_DIRECT_WEBHOOKS=true
